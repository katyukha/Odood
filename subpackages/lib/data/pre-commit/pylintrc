[MASTER]
load-plugins=pylint_odoo
score=n

[ODOOLINT]
manifest-deprecated-keys=description,active
valid-odoo-versions={{ project.odoo.serie }}
license-allowed=AGPL-3,GPL-2,GPL-2 or any later version,GPL-3,GPL-3 or any later version,LGPL-3,OPL-1,OEEL-1,Other proprietary,Other OSI approved licence

[MESSAGES CONTROL]
disable=all
enable=
  manifest-required-key,
  manifest-deprecated-key,
  license-allowed,
  manifest-version-format,
  translation-required,
  method-compute,
  method-search,
  method-inverse,
  development-status-allowed,
  no-wizard-in-models,
  category-allowed,
  missing-odoo-file,
  manifest-superfluous-key,
  category-allowed-app,
  missing-odoo-file-app,
  manifest-required-key-app,
  syntax-error,
  unrecognized-inline-option,
  bad-plugin-value,
  bad-configuration-section,
  unrecognized-option,
  manifest-author-string,
  invalid-commit,
  sql-injection,
  manifest-maintainers-list,
  external-request-timeout,
  test-folder-imported,
  no-write-in-compute,
  no-raise-unlink,
  manifest-behind-migrations,
  deprecated-name-get,
  inheritable-method-string,
  inheritable-method-lambda,
  deprecated-inselect-operator,
  translation-unsupported-format,
  translation-format-truncated,
  translation-too-many-args,
  translation-too-few-args,
  resource-not-exist,
  useless-option-value,
  odoo-exception-warning,
  consider-merging-classes-inherited,
  invalid-email,
  unknown-option-value,
  translation-field,
  attribute-deprecated,
  method-required-super,
  prohibited-method-override,
  missing-return,
  renamed-field-parameter,
  attribute-string-redundant,
  website-manifest-key-not-valid-uri,
  translation-contains-variable,
  print-used,
  translation-positional-used,
  context-overridden,
  manifest-data-duplicated,
  except-pass,
  odoo-addons-relative-import,
  bad-builtin-groupby,
  deprecated-odoo-model-method,
  prefer-env-translation,
  manifest-external-assets,
  no-search-all,
  super-method-mismatch,
  use-vim-comment,
  translation-not-lazy,
  translation-format-interpolation,
  translation-fstring-interpolation

# To be added
#  missing-readme,

[REPORTS]
msg-template={path}:{line}: [{msg_id}({symbol}), {obj}] {msg}
output-format=colorized
reports=no

[FORMAT]
indent-string='    '

[SIMILARITIES]
ignore-comments=yes
ignore-docstrings=yes
min-similarity-lines=8

[MISCELLANEOUS]
notes=TODO

[IMPORTS]
deprecated-modules=pdb,pudb,ipdb,openerp.osv
